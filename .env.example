# ==========================================
# CONFIGURAÇÕES DE BANCO DE DADOS
# ==========================================

# Opção A (Nuvem): 
# Utilize a DATABASE_URL da nuvem (Neon) que foi enviada no e-mail/plataforma de entrega.
# Cole a URL real abaixo e comente a Opção B.
DATABASE_URL="postgresql://usuario:senha@host:porta/banco?sslmode=require&channel_binding=require"

# Opção B (Local - Docker): 
# Suba o banco usando o comando 'docker-compose up -d'. 
# Lembre-se de substituir 'sua_senha_aqui' pela senha que você definir, se alterar o docker-compose.yml.
DATABASE_URL="postgresql://postgres:sua_senha_aqui@localhost:5432/jitterbit_db?schema=public"

# ==========================================
# SEGURANÇA (JWT)
# ==========================================

# Chave secreta para assinatura dos tokens. 
# Para testes lais, a string abaixo funcionará perfeitamente.
JWT_SECRET="jitterbit-teste-tecnico-2026"